#!/bin/bash

# 检查并安装缺失的命令
ensure_command() {
    if ! command -v "$1" >/dev/null 2>&1; then
        if [ "$(id -u)" -eq 0 ]; then
            echo "正在安装缺失的命令: $1"
            apk add --no-cache "$2" >/dev/null 2>&1 || {
                echo "安装失败: $1"
                return 1
            }
        else
            echo "需要管理员权限安装: $1"
            return 1
        fi
    fi
    return 0
}

# 确保必要命令存在
ensure_command "bash" "bash"
ensure_command "figlet" "figlet"
ensure_command "lscpu" "util-linux"
ensure_command "free" "procps"
ensure_command "df" "coreutils" >/dev/null 2>&1

# 获取系统信息
HOSTNAME=$(hostname)
KERNEL=$(uname -r)
UPTIME=$(uptime -p | sed 's/up //')
MEMORY=$(free -h | awk '/^Mem:/ {print $3 "/" $2}')
DISK=$(df -h | awk '$NF=="/" {print $3 "/" $2}')
CPU=$(lscpu 2>/dev/null | awk -F: '/Model name/ {print $2}' | xargs | sed 's/(R)//g; s/(TM)//g; s/  / /g')
[ -z "$CPU" ] && CPU=$(cat /proc/cpuinfo | grep -E 'model name|Hardware' | head -n1 | cut -d: -f2 | sed 's/^ *//;s/ *$//')
USER=$(whoami)
SHELL=$(basename "$SHELL")
TIME=$(date "+%Y-%m-%d %H:%M:%S")

# 清屏
clear

# 显示 Alpine 的 ASCII logo
figlet "Alpine Linux" 2>/dev/null || echo -e "\n\e[1;36mAlpine Linux\e[0m\n"

echo -e "\e[1;34m════════════════════════════════════════════════\e[0m"
echo -e "\e[1;32m    🌐  System Information\e[0m"
echo -e "\e[1;34m════════════════════════════════════════════════\e[0m"
echo -e "\n"

# 信息显示
echo -e "\e[1;33mHostname: \e[1;37m$HOSTNAME"
echo -e "\e[1;33mKernel: \e[1;37m$KERNEL"
echo -e "\e[1;33mUptime: \e[1;37m$UPTIME"
echo -e "\e[1;33mMemory: \e[1;37m$MEMORY"
echo -e "\e[1;33mDisk Usage: \e[1;37m$DISK"
echo -e "\e[1;33mCPU: \e[1;37m$CPU"
echo -e "\e[1;33mUser: \e[1;37m$USER"
echo -e "\e[1;33mShell: \e[1;37m$SHELL"
echo -e "\e[1;33mTime: \e[1;37m$TIME"
echo -e "\n"

# 图形化分隔符
echo -e "\e[1;34m════════════════════════════════════════════════\e[0m"
echo -e "\e[1;33m🌱 Enjoy your terminal session! 🌱\e[0m"
echo -e "\e[1;34m════════════════════════════════════════════════\e[0m"
